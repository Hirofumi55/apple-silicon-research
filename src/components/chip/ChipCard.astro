---
import type { ChipSpec } from '../../types/chip';

interface Props {
  chip: ChipSpec;
}

const { chip } = Astro.props;

// ベンチマーク表示用: Geekbench6マルチコアを優先
const benchmark = chip.benchmarks.geekbench6MultiCore
  ?? chip.benchmarks.antutu;
const benchmarkLabel = chip.benchmarks.geekbench6MultiCore
  ? 'GB6 Multi'
  : 'AnTuTu';

const seriesLabel = chip.series === 'm' ? 'Mac' : 'iPhone/iPad';
---

<a
  href={`/chip/${chip.slug}`}
  class="chip-card glass"
  style={`
    display: block;
    border-radius: 16px;
    padding: 24px;
    text-decoration: none;
    position: relative;
    overflow: hidden;
    --chip-color: ${chip.color};
  `}
>
  <!-- グロウ背景 -->
  <div style={`
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 50% 0%, ${chip.color}15 0%, transparent 70%);
    pointer-events: none;
    transition: opacity 0.3s ease;
  `} class="card-glow"></div>

  <!-- ヘッダー -->
  <div style="display: flex; align-items: flex-start; justify-content: space-between; margin-bottom: 16px; position: relative;">
    <!-- チップ識別ドット -->
    <div style={`
      width: 32px;
      height: 32px;
      border-radius: 8px;
      background: ${chip.color}25;
      border: 1px solid ${chip.color}40;
      display: flex;
      align-items: center;
      justify-content: center;
    `}>
      <div style={`width: 10px; height: 10px; border-radius: 50%; background: ${chip.color};`}></div>
    </div>

    <!-- シリーズバッジ -->
    <span style={`
      font-size: 10px;
      font-weight: 600;
      padding: 3px 8px;
      border-radius: 20px;
      background: ${chip.color}20;
      color: ${chip.color};
      border: 1px solid ${chip.color}40;
      letter-spacing: 0.5px;
      text-transform: uppercase;
    `}>
      {chip.series === 'm' ? 'M Series' : 'A Series'}
    </span>
  </div>

  <!-- チップ名 -->
  <div style="margin-bottom: 4px; position: relative;">
    <h3 style="font-size: 18px; font-weight: 700; color: var(--color-text); letter-spacing: -0.5px; margin: 0;">
      {chip.name}
    </h3>
    <p style="font-size: 12px; color: var(--color-text-secondary); margin: 4px 0 0;">{chip.releaseDate.replace('-', '年')}月発売</p>
  </div>

  <!-- スペック -->
  <div style="
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
    margin: 16px 0;
    position: relative;
  ">
    <div style="
      background: rgba(255,255,255,0.04);
      border-radius: 8px;
      padding: 10px;
    ">
      <div style="font-size: 10px; color: var(--color-text-secondary); margin-bottom: 2px; text-transform: uppercase; letter-spacing: 0.5px;">CPU</div>
      <div style="font-size: 16px; font-weight: 700; color: var(--color-text);">{chip.cpu.totalCores}</div>
      <div style="font-size: 10px; color: var(--color-text-secondary);">コア</div>
    </div>
    <div style="
      background: rgba(255,255,255,0.04);
      border-radius: 8px;
      padding: 10px;
    ">
      <div style="font-size: 10px; color: var(--color-text-secondary); margin-bottom: 2px; text-transform: uppercase; letter-spacing: 0.5px;">GPU</div>
      <div style="font-size: 16px; font-weight: 700; color: var(--color-text);">{chip.gpu.maxCores ?? chip.gpu.cores}</div>
      <div style="font-size: 10px; color: var(--color-text-secondary);">コア</div>
    </div>
    <div style="
      background: rgba(255,255,255,0.04);
      border-radius: 8px;
      padding: 10px;
    ">
      <div style="font-size: 10px; color: var(--color-text-secondary); margin-bottom: 2px; text-transform: uppercase; letter-spacing: 0.5px;">Process</div>
      <div style="font-size: 13px; font-weight: 700; color: var(--color-text); line-height: 1.2;">{chip.processNode}</div>
    </div>
    <div style="
      background: rgba(255,255,255,0.04);
      border-radius: 8px;
      padding: 10px;
    ">
      <div style="font-size: 10px; color: var(--color-text-secondary); margin-bottom: 2px; text-transform: uppercase; letter-spacing: 0.5px;">Neural</div>
      <div style="font-size: 14px; font-weight: 700; color: var(--color-text);">{chip.neuralEngine.tops}</div>
      <div style="font-size: 10px; color: var(--color-text-secondary);">TOPS</div>
    </div>
  </div>

  <!-- ベンチマーク -->
  {benchmark && (
    <div style="
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 10px 12px;
      background: rgba(255,255,255,0.03);
      border-radius: 8px;
      border: 1px solid var(--color-border);
      position: relative;
    ">
      <span style="font-size: 11px; color: var(--color-text-secondary);">{benchmarkLabel}</span>
      <span style={`font-size: 15px; font-weight: 700; color: ${chip.color};`}>
        {benchmark.toLocaleString('ja-JP')}
      </span>
    </div>
  )}

  <!-- ホバーの矢印 -->
  <div style="
    position: absolute;
    bottom: 16px;
    right: 16px;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: var(--color-accent);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transform: scale(0.8);
    transition: all 0.2s ease;
  " class="card-arrow">
    <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
      <path d="M2 6H10M6 2L10 6L6 10" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </div>
</a>

<style>
  .chip-card:hover .card-glow {
    opacity: 1.5;
  }

  .chip-card:hover .card-arrow {
    opacity: 1 !important;
    transform: scale(1) !important;
  }

  .chip-card:hover {
    border-color: var(--chip-color, var(--color-border)) !important;
    box-shadow: 0 0 30px -5px color-mix(in srgb, var(--chip-color, #0071e3) 30%, transparent);
  }

  .light .chip-card:hover {
    box-shadow: 0 8px 32px -4px color-mix(in srgb, var(--chip-color, #0071e3) 20%, transparent);
  }
</style>
