---
import ThemeToggle from './ThemeToggle.tsx';

const navItems = [
  { href: '/', label: 'ホーム' },
  { href: '/m-series', label: 'Mシリーズ' },
  { href: '/a-series', label: 'Aシリーズ' },
  { href: '/compare', label: '比較' },
  { href: '/timeline', label: 'タイムライン' },
  { href: '/architecture', label: '技術解説' },
];

const currentPath = Astro.url.pathname;
---

<header id="site-header" style="position: fixed; top: 0; left: 0; right: 0; z-index: 100; transition: all 0.3s ease;">
  <div style="
    background: rgba(0, 0, 0, 0.01);
    border-bottom: 1px solid transparent;
    transition: all 0.3s ease;
    padding: 0 clamp(16px, 5vw, 48px);
  " id="header-inner">
    <div style="max-width: 1200px; margin: 0 auto; height: 56px; display: flex; align-items: center; justify-content: space-between;">

      <!-- ロゴ -->
      <a href="/" style="text-decoration: none; display: flex; align-items: center; gap: 8px;">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="10" cy="10" r="9" stroke="var(--color-accent)" stroke-width="1.5"/>
          <circle cx="10" cy="10" r="4" fill="var(--color-accent)" opacity="0.8"/>
          <circle cx="10" cy="10" r="1.5" fill="white"/>
        </svg>
        <span style="font-size: 15px; font-weight: 600; color: var(--color-text); letter-spacing: -0.3px;">
          Silicon Lab
        </span>
      </a>

      <!-- デスクトップナビ -->
      <nav style="display: flex; align-items: center; gap: 2px;" class="desktop-nav">
        {navItems.map(item => (
          <a
            href={item.href}
            style={`
              font-size: 13px;
              font-weight: 400;
              padding: 6px 12px;
              border-radius: 6px;
              text-decoration: none;
              transition: all 0.2s ease;
              color: ${currentPath === item.href ? 'var(--color-accent)' : 'var(--color-text-secondary)'};
              background: ${currentPath === item.href ? 'rgba(0, 113, 227, 0.1)' : 'transparent'};
            `}
            class="nav-link"
          >
            {item.label}
          </a>
        ))}
      </nav>

      <!-- 右側アクション -->
      <div style="display: flex; align-items: center; gap: 12px;">
        <ThemeToggle client:load />

        <!-- モバイルメニューボタン -->
        <button
          id="mobile-menu-btn"
          aria-label="メニューを開く"
          style="
            display: none;
            padding: 6px;
            background: transparent;
            border: 1px solid var(--color-border);
            border-radius: 6px;
            cursor: pointer;
            color: var(--color-text);
          "
          class="mobile-only"
        >
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
            <line x1="2" y1="5" x2="16" y2="5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            <line x1="2" y1="9" x2="16" y2="9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            <line x1="2" y1="13" x2="16" y2="13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- モバイルメニュー -->
  <div
    id="mobile-menu"
    style="
      display: none;
      background: var(--color-surface);
      border-bottom: 1px solid var(--color-border);
      padding: 16px clamp(16px, 5vw, 48px);
    "
  >
    {navItems.map(item => (
      <a
        href={item.href}
        style={`
          display: block;
          font-size: 15px;
          padding: 12px 0;
          border-bottom: 1px solid var(--color-border);
          text-decoration: none;
          color: ${currentPath === item.href ? 'var(--color-accent)' : 'var(--color-text)'};
        `}
      >
        {item.label}
      </a>
    ))}
  </div>
</header>

<!-- ヘッダーの高さ分スペースを確保 -->
<div style="height: 56px;"></div>

<style>
  @media (max-width: 768px) {
    .desktop-nav {
      display: none !important;
    }
    .mobile-only {
      display: flex !important;
    }
  }

  .nav-link:hover {
    color: var(--color-text) !important;
    background: rgba(255, 255, 255, 0.05) !important;
  }

  .light .nav-link:hover {
    background: rgba(0, 0, 0, 0.05) !important;
  }
</style>

<script>
  // スクロール時のヘッダー背景変更（ダーク/ライトモード対応）
  const headerInner = document.getElementById('header-inner');

  const getScrolledBg = () => {
    const isLight = document.documentElement.classList.contains('light');
    return isLight ? 'rgba(255, 255, 255, 0.85)' : 'rgba(0, 0, 0, 0.82)';
  };

  const updateHeader = () => {
    if (!headerInner) return;
    if (window.scrollY > 20) {
      headerInner.style.background = getScrolledBg();
      headerInner.style.backdropFilter = 'blur(20px)';
      headerInner.style.webkitBackdropFilter = 'blur(20px)';
      headerInner.style.borderBottomColor = 'var(--color-border)';
    } else {
      headerInner.style.background = 'transparent';
      headerInner.style.backdropFilter = 'none';
      headerInner.style.webkitBackdropFilter = 'none';
      headerInner.style.borderBottomColor = 'transparent';
    }
  };

  window.addEventListener('scroll', updateHeader, { passive: true });

  // テーマ変更時にも再適用
  const observer = new MutationObserver(updateHeader);
  observer.observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });

  // 初期適用
  updateHeader();

  // モバイルメニュー
  const mobileMenuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  let menuOpen = false;

  mobileMenuBtn?.addEventListener('click', () => {
    menuOpen = !menuOpen;
    mobileMenu!.style.display = menuOpen ? 'block' : 'none';
    mobileMenuBtn.setAttribute('aria-expanded', String(menuOpen));
  });
</script>
