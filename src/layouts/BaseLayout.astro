---
import { ViewTransitions } from 'astro:transitions';
import Header from '../components/common/Header.astro';
import Footer from '../components/common/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  jsonLd?: Record<string, unknown>;
}

const {
  title,
  description = 'Apple M1〜M5 / A15〜A19チップの性能・ベンチマーク完全比較サイト。スペック比較、ベンチマークグラフ、世代進化タイムラインを掲載。',
  ogImage = '/images/og/default.svg',
  jsonLd,
} = Astro.props;

// og:image を絶対URLに変換（SNSクローラー対応）
const siteBase = Astro.site ?? new URL('https://apple-silicon-research.pages.dev');
const ogImageAbsolute = ogImage.startsWith('http')
  ? ogImage
  : new URL(ogImage, siteBase).toString();

// デフォルトのサイト構造化データ
const defaultJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Apple Silicon Lab',
  url: 'https://apple-silicon-research.pages.dev',
  description: 'Apple M1〜M5 / A15〜A19チップの性能・ベンチマーク完全比較サイト',
  inLanguage: 'ja',
  potentialAction: {
    '@type': 'SearchAction',
    target: 'https://apple-silicon-research.pages.dev/compare?chips={search_term_string}',
    'query-input': 'required name=search_term_string',
  },
};

const structuredData = jsonLd ?? defaultJsonLd;

const fullTitle = title === 'Apple Silicon Lab'
  ? 'Apple Silicon Lab | M1〜M5 / Aシリーズ チップ性能完全比較'
  : `${title} | Apple Silicon Lab`;
---

<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#0071e3" />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageAbsolute} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="ja_JP" />
    <meta property="og:site_name" content="Apple Silicon Lab" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageAbsolute} />

    <!-- Canonical -->
    <link rel="canonical" href={Astro.url.href} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />

    <!-- PWA -->
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="Silicon Lab" />

    <!-- View Transitions -->
    <ViewTransitions />

    <!-- 構造化データ JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />

    <!-- テーマ初期化スクリプト（FOUC防止） -->
    <script is:inline>
      (function() {
        var saved = localStorage.getItem('theme');
        if (saved === 'light') {
          document.documentElement.classList.add('light');
        } else if (!saved) {
          var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          if (!prefersDark) {
            document.documentElement.classList.add('light');
          }
        }
      })();
    </script>
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />

    <!-- ページトップへボタン -->
    <button
      id="back-to-top"
      aria-label="ページの先頭へ戻る"
      style="
        position: fixed;
        bottom: 32px;
        right: 32px;
        width: 44px;
        height: 44px;
        border-radius: 50%;
        background: var(--color-accent);
        color: white;
        border: none;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 4px 20px rgba(0, 113, 227, 0.4);
        opacity: 0;
        transform: translateY(12px);
        transition: opacity 0.3s ease, transform 0.3s ease;
        pointer-events: none;
        z-index: 50;
      "
    >
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
        <path d="M8 12V4M4 8L8 4L12 8" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>

    <script is:inline>
      (function() {
        var btn = document.getElementById('back-to-top');
        if (!btn) return;
        window.addEventListener('scroll', function() {
          if (window.scrollY > 400) {
            btn.style.opacity = '1';
            btn.style.transform = 'translateY(0)';
            btn.style.pointerEvents = 'auto';
          } else {
            btn.style.opacity = '0';
            btn.style.transform = 'translateY(12px)';
            btn.style.pointerEvents = 'none';
          }
        }, { passive: true });
        btn.addEventListener('click', function() {
          window.scrollTo({ top: 0, behavior: 'smooth' });
        });
      })();
    </script>
  </body>
</html>
