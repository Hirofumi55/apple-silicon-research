---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="ページが見つかりません" description="お探しのページは存在しないか、移動した可能性があります。">
  <section style="
    min-height: 70vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 80px clamp(16px, 5vw, 48px);
    text-align: center;
  ">
    <div style="max-width: 500px;">
      <!-- 404 大文字 -->
      <div style="
        font-size: clamp(80px, 18vw, 160px);
        font-weight: 800;
        letter-spacing: -8px;
        line-height: 1;
        margin-bottom: 24px;
        background: linear-gradient(135deg, rgba(255,255,255,0.1) 0%, rgba(255,255,255,0.03) 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        position: relative;
      ">
        404
        <!-- グロウ -->
        <div style="
          position: absolute;
          top: 50%;
          left: 50%;
          transform: translate(-50%, -50%);
          width: 200px;
          height: 200px;
          background: radial-gradient(circle, rgba(0,113,227,0.15) 0%, transparent 70%);
          pointer-events: none;
          z-index: -1;
        "></div>
      </div>

      <h1 style="font-size: 22px; font-weight: 700; color: var(--color-text); margin-bottom: 12px; letter-spacing: -0.5px;">
        ページが見つかりません
      </h1>
      <p style="font-size: 15px; color: var(--color-text-secondary); margin-bottom: 40px; line-height: 1.7;">
        お探しのページは存在しないか、<br>移動した可能性があります。
      </p>

      <div style="display: flex; gap: 12px; justify-content: center; flex-wrap: wrap;">
        <a href="/" style="
          display: inline-flex;
          align-items: center;
          gap: 8px;
          padding: 12px 24px;
          background: var(--color-accent);
          color: white;
          border-radius: 980px;
          text-decoration: none;
          font-size: 14px;
          font-weight: 600;
          transition: all 0.2s ease;
        ">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
            <path d="M7 1L1 7L7 13" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            <line x1="1" y1="7" x2="13" y2="7" stroke="white" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
          ホームへ戻る
        </a>
        <a href="/compare" style="
          display: inline-flex;
          align-items: center;
          gap: 8px;
          padding: 12px 24px;
          background: var(--color-surface);
          color: var(--color-text);
          border-radius: 980px;
          text-decoration: none;
          font-size: 14px;
          font-weight: 500;
          border: 1px solid var(--color-border);
          transition: all 0.2s ease;
        ">
          チップを比較する
        </a>
      </div>

      <!-- チップへのクイックリンク -->
      <div style="margin-top: 56px; padding-top: 40px; border-top: 1px solid var(--color-border);">
        <p style="font-size: 12px; color: var(--color-text-secondary); margin-bottom: 16px; text-transform: uppercase; letter-spacing: 1px;">人気のページ</p>
        <div style="display: flex; flex-wrap: wrap; gap: 8px; justify-content: center;">
          {[
            { href: '/m-series', label: 'Mシリーズ比較' },
            { href: '/a-series', label: 'Aシリーズ比較' },
            { href: '/chip/m5', label: 'M5' },
            { href: '/chip/m4', label: 'M4' },
            { href: '/chip/a19-pro', label: 'A19 Pro' },
            { href: '/timeline', label: 'タイムライン' },
          ].map(link => (
            <a href={link.href} style="
              font-size: 12px;
              padding: 6px 12px;
              border-radius: 20px;
              background: var(--color-surface);
              color: var(--color-text-secondary);
              text-decoration: none;
              border: 1px solid var(--color-border);
              transition: all 0.2s ease;
            " class="quick-link">
              {link.label}
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .quick-link:hover {
    color: var(--color-accent) !important;
    border-color: var(--color-accent) !important;
  }
</style>
