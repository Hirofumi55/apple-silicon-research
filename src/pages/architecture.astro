---
import BaseLayout from '../layouts/BaseLayout.astro';

const architectureJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'TechArticle',
  headline: 'Apple Silicon アーキテクチャ技術解説',
  description: 'ユニファイドメモリ、プロセスノードの進化（5nm→3nm→2nm）、CPU/GPU/Neural Engineの構造、UltraFusionの仕組みを詳細解説。',
  url: 'https://apple-silicon-research.pages.dev/architecture',
  inLanguage: 'ja',
  about: { '@type': 'Thing', name: 'Apple Silicon アーキテクチャ' },
  breadcrumb: {
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'ホーム', item: 'https://apple-silicon-research.pages.dev' },
      { '@type': 'ListItem', position: 2, name: '技術解説', item: 'https://apple-silicon-research.pages.dev/architecture' },
    ],
  },
};
---

<BaseLayout
  title="技術解説"
  description="Apple Siliconのアーキテクチャ解説。ユニファイドメモリ、プロセスノードの進化（5nm→3nm→2nm）、CPU/GPU/Neural Engineの構造、Pro/Max/Ultra のスケーリング仕組みを詳細解説。"
  jsonLd={architectureJsonLd}
>
  <section style="
    padding: clamp(60px, 8vw, 100px) clamp(16px, 5vw, 48px) 0;
    max-width: 1200px;
    margin: 0 auto;
  ">
    <div class="reveal">
      <div style="display: inline-flex; align-items: center; gap: 8px; margin-bottom: 20px;">
        <a href="/" style="font-size: 13px; color: var(--color-text-secondary); text-decoration: none;">ホーム</a>
        <span style="color: var(--color-text-secondary);">/</span>
        <span style="font-size: 13px; color: var(--color-text);">技術解説</span>
      </div>
      <h1 style="
        font-size: clamp(32px, 6vw, 64px);
        font-weight: 800;
        color: var(--color-text);
        letter-spacing: -2px;
        margin-bottom: 16px;
      ">Apple Silicon<br><span class="text-gradient-accent">技術解説</span></h1>
      <p style="font-size: 16px; color: var(--color-text-secondary); max-width: 600px; line-height: 1.7;">
        ユニファイドメモリアーキテクチャからUltraFusionまで。Apple Siliconを支える革新的な技術を解説。
      </p>
    </div>
  </section>

  <!-- ユニファイドメモリ -->
  <section class="section-padding">
    <div class="container-max">
      <div style="
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 64px;
        align-items: center;
      " class="reveal">
        <div>
          <div style="
            display: inline-flex;
            align-items: center;
            gap: 8px;
            margin-bottom: 16px;
          ">
            <div style="width: 24px; height: 2px; background: var(--color-accent);"></div>
            <span style="font-size: 13px; font-weight: 600; color: var(--color-accent); text-transform: uppercase; letter-spacing: 1px;">Unified Memory</span>
          </div>
          <h2 style="font-size: 32px; font-weight: 800; color: var(--color-text); letter-spacing: -1px; margin-bottom: 20px;">
            ユニファイドメモリ<br>アーキテクチャ
          </h2>
          <p style="font-size: 15px; color: var(--color-text-secondary); line-height: 1.8; margin-bottom: 16px;">
            従来のコンピュータでは、CPU用メモリとGPU用VRAM が別々に存在し、データの受け渡しに時間とエネルギーが必要でした。
          </p>
          <p style="font-size: 15px; color: var(--color-text-secondary); line-height: 1.8; margin-bottom: 16px;">
            Apple Siliconのユニファイドメモリは<strong style="color: var(--color-text);">CPU・GPU・Neural Engineが同一のメモリプールを共有</strong>します。これにより：
          </p>
          <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 12px;">
            {[
              'データコピーが不要で低レイテンシー',
              'メモリ帯域幅を全プロセッサで最大活用',
              '電力消費を大幅に削減',
              '実効的なメモリ容量が増大',
            ].map(item => (
              <li style="display: flex; align-items: center; gap: 10px; font-size: 14px; color: var(--color-text);">
                <div style="width: 6px; height: 6px; border-radius: 50%; background: var(--color-accent); flex-shrink: 0;"></div>
                {item}
              </li>
            ))}
          </ul>
        </div>

        <!-- アーキテクチャ図 -->
        <div style="
          padding: 40px;
          background: var(--color-surface);
          border-radius: 20px;
          border: 1px solid var(--color-border);
        ">
          <svg viewBox="0 0 300 260" fill="none" style="width: 100%;">
            <!-- メモリ（中央） -->
            <rect x="80" y="100" width="140" height="60" rx="8" fill="rgba(0,113,227,0.15)" stroke="#0071e3" stroke-width="1.5"/>
            <text x="150" y="126" text-anchor="middle" fill="#0071e3" font-size="11" font-weight="600">Unified Memory</text>
            <text x="150" y="143" text-anchor="middle" fill="#a1a1a6" font-size="9">最大128GB LPDDR5X</text>

            <!-- CPU -->
            <rect x="10" y="20" width="80" height="50" rx="6" fill="rgba(255,107,107,0.15)" stroke="#FF6B6B" stroke-width="1"/>
            <text x="50" y="41" text-anchor="middle" fill="#FF6B6B" font-size="10" font-weight="600">CPU</text>
            <text x="50" y="57" text-anchor="middle" fill="#a1a1a6" font-size="8">最大32コア</text>

            <!-- GPU -->
            <rect x="110" y="20" width="80" height="50" rx="6" fill="rgba(78,205,196,0.15)" stroke="#4ECDC4" stroke-width="1"/>
            <text x="150" y="41" text-anchor="middle" fill="#4ECDC4" font-size="10" font-weight="600">GPU</text>
            <text x="150" y="57" text-anchor="middle" fill="#a1a1a6" font-size="8">最大80コア</text>

            <!-- Neural Engine -->
            <rect x="210" y="20" width="80" height="50" rx="6" fill="rgba(150,206,180,0.15)" stroke="#96CEB4" stroke-width="1"/>
            <text x="250" y="41" text-anchor="middle" fill="#96CEB4" font-size="10" font-weight="600">Neural</text>
            <text x="250" y="57" text-anchor="middle" fill="#a1a1a6" font-size="8">45 TOPS</text>

            <!-- 接続ライン -->
            <line x1="50" y1="70" x2="120" y2="100" stroke="rgba(255,255,255,0.2)" stroke-width="1" stroke-dasharray="4,2"/>
            <line x1="150" y1="70" x2="150" y2="100" stroke="rgba(255,255,255,0.2)" stroke-width="1" stroke-dasharray="4,2"/>
            <line x1="250" y1="70" x2="180" y2="100" stroke="rgba(255,255,255,0.2)" stroke-width="1" stroke-dasharray="4,2"/>

            <!-- I/Oブロック -->
            <rect x="10" y="190" width="60" height="35" rx="4" fill="rgba(255,255,255,0.05)" stroke="rgba(255,255,255,0.15)" stroke-width="1"/>
            <text x="40" y="211" text-anchor="middle" fill="#a1a1a6" font-size="8">Thunderbolt</text>

            <rect x="80" y="190" width="60" height="35" rx="4" fill="rgba(255,255,255,0.05)" stroke="rgba(255,255,255,0.15)" stroke-width="1"/>
            <text x="110" y="211" text-anchor="middle" fill="#a1a1a6" font-size="8">ISP</text>

            <rect x="150" y="190" width="60" height="35" rx="4" fill="rgba(255,255,255,0.05)" stroke="rgba(255,255,255,0.15)" stroke-width="1"/>
            <text x="180" y="211" text-anchor="middle" fill="#a1a1a6" font-size="8">ProRes</text>

            <rect x="220" y="190" width="70" height="35" rx="4" fill="rgba(255,255,255,0.05)" stroke="rgba(255,255,255,0.15)" stroke-width="1"/>
            <text x="255" y="211" text-anchor="middle" fill="#a1a1a6" font-size="8">Secure Enclave</text>

            <!-- I/O接続 -->
            <line x1="40" y1="190" x2="100" y2="160" stroke="rgba(255,255,255,0.1)" stroke-width="0.5"/>
            <line x1="110" y1="190" x2="140" y2="160" stroke="rgba(255,255,255,0.1)" stroke-width="0.5"/>
            <line x1="180" y1="190" x2="160" y2="160" stroke="rgba(255,255,255,0.1)" stroke-width="0.5"/>
            <line x1="255" y1="190" x2="200" y2="160" stroke="rgba(255,255,255,0.1)" stroke-width="0.5"/>

            <!-- 帯域幅表示 -->
            <text x="150" y="253" text-anchor="middle" fill="#0071e3" font-size="10" font-weight="600">最大614 GB/s (M5 Max)</text>
          </svg>
        </div>
      </div>
    </div>
  </section>

  <!-- プロセスノード進化 -->
  <section class="section-padding" style="background: var(--color-surface);">
    <div class="container-max">
      <h2 style="font-size: 28px; font-weight: 800; color: var(--color-text); letter-spacing: -1px; margin-bottom: 48px;" class="reveal">
        プロセスノードの進化
      </h2>

      <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px;" class="reveal">
        {[
          { node: '5nm', chips: 'M1, M2, A15, A16', years: '2020-2022', color: '#FF6B6B', desc: 'TSMC N5プロセスを採用。業界初のMac向けARMチップで、x86を超える効率を実現。' },
          { node: '3nm', chips: 'M3, M4, M5, A17, A18, A19', years: '2023-2026', color: '#45B7D1', desc: 'TSMC N3e/N3Pプロセス。同一ダイサイズでより多くのトランジスタを集積可能。' },
          { node: '2nm?', chips: 'M6?, A20?', years: '2027〜予想', color: '#96CEB4', desc: 'TSMCの次世代N2プロセス（ナノシート/GAAFET技術）での更なる性能・効率向上が期待される。' },
        ].map(item => (
          <div style={`
            padding: 28px;
            background: var(--color-bg);
            border-radius: 16px;
            border: 1px solid var(--color-border);
            border-top: 3px solid ${item.color};
          `}>
            <div style={`font-size: 40px; font-weight: 800; color: ${item.color}; letter-spacing: -2px; margin-bottom: 4px;`}>{item.node}</div>
            <div style="font-size: 12px; color: var(--color-text-secondary); margin-bottom: 12px;">{item.years}</div>
            <div style="font-size: 13px; font-weight: 600; color: var(--color-text); margin-bottom: 8px;">{item.chips}</div>
            <p style="font-size: 13px; color: var(--color-text-secondary); line-height: 1.6;">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Pro / Max / Ultra スケーリング -->
  <section class="section-padding">
    <div class="container-max">
      <h2 style="font-size: 28px; font-weight: 800; color: var(--color-text); letter-spacing: -1px; margin-bottom: 16px;" class="reveal">
        バリアント戦略
      </h2>
      <p style="font-size: 15px; color: var(--color-text-secondary); max-width: 600px; line-height: 1.7; margin-bottom: 48px;" class="reveal">
        Appleは同一のベースチップから複数のバリアントを展開することで、幅広い製品ラインアップを効率的にカバーしています。
      </p>

      <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 2px; background: var(--color-border); border-radius: 16px; overflow: hidden;" class="reveal">
        {[
          { name: 'Base', desc: 'MacBook Air / エントリーMacBook Pro / iPad Pro / iMac', specs: '最大10コアCPU / 10コアGPU / 32GB RAM', color: '#a1a1a6' },
          { name: 'Pro', desc: 'MacBook Pro / Mac mini', specs: '最大18コアCPU / 20コアGPU / 64GB RAM', color: '#4ECDC4' },
          { name: 'Max', desc: 'MacBook Pro 16" / Mac Studio', specs: '最大18コアCPU / 40コアGPU / 128GB RAM', color: '#DDA0DD' },
          { name: 'Ultra', desc: 'Mac Studio / Mac Pro', specs: 'Max×2 / 最大80コアGPU / 192GB RAM', color: '#F7DC6F' },
        ].map(item => (
          <div style={`
            padding: 28px 20px;
            background: var(--color-surface);
            text-align: center;
          `}>
            <div style={`font-size: 20px; font-weight: 800; color: ${item.color}; margin-bottom: 8px;`}>{item.name}</div>
            <div style="font-size: 11px; color: var(--color-text-secondary); line-height: 1.5; margin-bottom: 12px;">{item.desc}</div>
            <div style={`font-size: 12px; color: ${item.color}; font-weight: 500; line-height: 1.5;`}>{item.specs}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- UltraFusion -->
  <section class="section-padding" style="background: var(--color-surface);">
    <div class="container-max">
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 64px; align-items: center;" class="reveal">
        <div>
          <div style="display: inline-flex; align-items: center; gap: 8px; margin-bottom: 16px;">
            <div style="width: 24px; height: 2px; background: #F7DC6F;"></div>
            <span style="font-size: 13px; font-weight: 600; color: #F7DC6F; text-transform: uppercase; letter-spacing: 1px;">UltraFusion</span>
          </div>
          <h2 style="font-size: 32px; font-weight: 800; color: var(--color-text); letter-spacing: -1px; margin-bottom: 20px;">
            2チップを<br>1つとして扱う
          </h2>
          <p style="font-size: 15px; color: var(--color-text-secondary); line-height: 1.8; margin-bottom: 16px;">
            UltraFusionはAppleが開発した独自のインターコネクト技術。M1 UltraからM3 Ultraまで使用されてきました。
          </p>
          <p style="font-size: 15px; color: var(--color-text-secondary); line-height: 1.8; margin-bottom: 16px;">
            2つのMaxチップをシリコンインターポーザーで直接接続することで：
          </p>
          <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 12px;">
            {[
              '2.5TB/sの超高速インターコネクト帯域',
              'OSには単一チップとして認識される',
              '2個分のCPU・GPU・Neural Engineを透過的に活用',
              '従来のマルチチップシステムのオーバーヘッドを排除',
            ].map(item => (
              <li style="display: flex; align-items: center; gap: 10px; font-size: 14px; color: var(--color-text);">
                <div style="width: 6px; height: 6px; border-radius: 50%; background: #F7DC6F; flex-shrink: 0;"></div>
                {item}
              </li>
            ))}
          </ul>
        </div>

        <!-- UltraFusion図解 -->
        <div style="
          padding: 40px;
          background: var(--color-bg);
          border-radius: 20px;
          border: 1px solid var(--color-border);
        ">
          <svg viewBox="0 0 300 200" fill="none" style="width: 100%;">
            <!-- チップ1 -->
            <rect x="10" y="40" width="120" height="120" rx="8" fill="rgba(221,160,221,0.1)" stroke="#DDA0DD" stroke-width="1.5"/>
            <text x="70" y="85" text-anchor="middle" fill="#DDA0DD" font-size="10" font-weight="600">M? Max</text>
            <text x="70" y="100" text-anchor="middle" fill="#a1a1a6" font-size="8">Die 1</text>
            <text x="70" y="130" text-anchor="middle" fill="#a1a1a6" font-size="7">CPU / GPU / NE</text>
            <text x="70" y="142" text-anchor="middle" fill="#a1a1a6" font-size="7">Memory Controller</text>

            <!-- チップ2 -->
            <rect x="170" y="40" width="120" height="120" rx="8" fill="rgba(221,160,221,0.1)" stroke="#DDA0DD" stroke-width="1.5"/>
            <text x="230" y="85" text-anchor="middle" fill="#DDA0DD" font-size="10" font-weight="600">M? Max</text>
            <text x="230" y="100" text-anchor="middle" fill="#a1a1a6" font-size="8">Die 2</text>
            <text x="230" y="130" text-anchor="middle" fill="#a1a1a6" font-size="7">CPU / GPU / NE</text>
            <text x="230" y="142" text-anchor="middle" fill="#a1a1a6" font-size="7">Memory Controller</text>

            <!-- 接続 -->
            <rect x="130" y="80" width="40" height="40" rx="4" fill="rgba(247,220,111,0.2)" stroke="#F7DC6F" stroke-width="1"/>
            <text x="150" y="98" text-anchor="middle" fill="#F7DC6F" font-size="7" font-weight="600">Ultra</text>
            <text x="150" y="109" text-anchor="middle" fill="#F7DC6F" font-size="7">Fusion</text>

            <!-- 帯域幅表示 -->
            <text x="150" y="185" text-anchor="middle" fill="#F7DC6F" font-size="9" font-weight="600">2.5 TB/s インターコネクト</text>
          </svg>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  @media (max-width: 768px) {
    section > div > div[style*="grid-template-columns: 1fr 1fr"] {
      grid-template-columns: 1fr !important;
    }
    section > div > div[style*="grid-template-columns: repeat(3, 1fr)"] {
      grid-template-columns: 1fr !important;
    }
    section > div > div[style*="grid-template-columns: repeat(4, 1fr)"] {
      grid-template-columns: repeat(2, 1fr) !important;
    }
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  gsap.utils.toArray<HTMLElement>('.reveal').forEach((el) => {
    gsap.fromTo(el, { y: 40, opacity: 0 }, {
      y: 0, opacity: 1, duration: 0.8, ease: 'power3.out',
      scrollTrigger: { trigger: el, start: 'top 85%', toggleActions: 'play none none none' },
    });
  });
</script>
