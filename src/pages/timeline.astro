---
import BaseLayout from '../layouts/BaseLayout.astro';
import type { ChipSpec } from '../types/chip';
import chipsData from '../data/chips.json';

const chips = chipsData as ChipSpec[];
// 発売順にソート
const sorted = [...chips].sort((a, b) => a.releaseDate.localeCompare(b.releaseDate));

// バー表示用最大値
const maxGB6Multi = Math.max(...chips.map(c => c.benchmarks.geekbench6MultiCore ?? 0));
const maxAnTuTu   = Math.max(...chips.map(c => c.benchmarks.antutu ?? 0));
const maxCpuCores = Math.max(...chips.map(c => c.cpu.totalCores));
const maxGpuCores = Math.max(...chips.map(c => c.gpu.maxCores ?? c.gpu.cores));

// 年ごとにグループ
const byYear = sorted.reduce<Record<string, ChipSpec[]>>((acc, chip) => {
  const year = chip.releaseDate.split('-')[0];
  if (!acc[year]) acc[year] = [];
  acc[year].push(chip);
  return acc;
}, {});

const years = Object.keys(byYear).sort();

const timelineJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  name: 'Apple Silicon 進化タイムライン',
  description: 'M1（2020年）からM5 Max（2026年）、A15〜A19 Proまで全チップの発売歴史',
  url: 'https://apple-silicon-research.pages.dev/timeline',
  inLanguage: 'ja',
  breadcrumb: {
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'ホーム', item: 'https://apple-silicon-research.pages.dev' },
      { '@type': 'ListItem', position: 2, name: 'タイムライン', item: 'https://apple-silicon-research.pages.dev/timeline' },
    ],
  },
};
---

<BaseLayout
  title="Apple Silicon タイムライン"
  description="Apple Silicon進化の歴史。M1（2020年）からM5 Max（2026年）、A15（2021年）からA19 Pro（2025年）まで、全チップの発売時期と特徴をタイムラインで確認。"
  jsonLd={timelineJsonLd}
>
  <section style="
    padding: clamp(60px, 8vw, 100px) clamp(16px, 5vw, 48px) 0;
    max-width: 1200px;
    margin: 0 auto;
  ">
    <div class="reveal">
      <div style="display: inline-flex; align-items: center; gap: 8px; margin-bottom: 20px;">
        <a href="/" style="font-size: 13px; color: var(--color-text-secondary); text-decoration: none;">ホーム</a>
        <span style="color: var(--color-text-secondary);">/</span>
        <span style="font-size: 13px; color: var(--color-text);">タイムライン</span>
      </div>
      <h1 style="
        font-size: clamp(32px, 6vw, 64px);
        font-weight: 800;
        color: var(--color-text);
        letter-spacing: -2px;
        margin-bottom: 16px;
      ">Apple Silicon<br><span class="text-gradient-accent">進化の歴史</span></h1>
      <p style="font-size: 16px; color: var(--color-text-secondary); max-width: 560px; line-height: 1.7;">
        2020年のM1登場から2026年まで。Appleシリコンの革命的な進化を時系列で振り返る。
      </p>
    </div>
  </section>

  <!-- タイムライン -->
  <section class="section-padding">
    <div class="container-max">
      <div style="position: relative; padding-left: 40px;">
        <!-- タイムラインライン -->
        <div style="
          position: absolute;
          left: 0;
          top: 0;
          bottom: 0;
          width: 2px;
          background: linear-gradient(180deg, var(--color-accent), #BB8FCE);
          border-radius: 1px;
        "></div>

        {years.map((year, yi) => (
          <div style="margin-bottom: 64px;" class="reveal">
            <!-- 年ラベル -->
            <div style="
              display: flex;
              align-items: center;
              gap: 16px;
              margin-bottom: 32px;
              position: relative;
            ">
              <div style="
                position: absolute;
                left: -49px;
                width: 18px;
                height: 18px;
                border-radius: 50%;
                background: var(--color-accent);
                border: 3px solid var(--color-bg);
                box-shadow: 0 0 12px rgba(0, 113, 227, 0.5);
              "></div>
              <h2 style="
                font-size: 32px;
                font-weight: 800;
                color: var(--color-text);
                letter-spacing: -1px;
              ">{year}</h2>
            </div>

            <!-- その年のチップ -->
            <div style="
              display: grid;
              grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
              gap: 16px;
            ">
              {byYear[year].map(chip => (
                <a href={`/chip/${chip.slug}`} style="
                  display: block;
                  padding: 20px 24px;
                  background: var(--color-surface);
                  border-radius: 12px;
                  border: 1px solid var(--color-border);
                  text-decoration: none;
                  transition: all 0.2s ease;
                " class="timeline-card">
                  <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 10px;">
                    <div style={`width: 10px; height: 10px; border-radius: 50%; background: ${chip.color};`}></div>
                    <span style="font-size: 15px; font-weight: 700; color: var(--color-text);">{chip.name}</span>
                    <span style={`font-size: 11px; color: ${chip.color}; margin-left: auto;`}>{chip.processNode}</span>
                  </div>
                  <p style="font-size: 12px; color: var(--color-text-secondary); line-height: 1.6; margin-bottom: 10px;">
                    {chip.description.slice(0, 60)}…
                  </p>
                  <!-- スペック mini-bars -->
                  {(() => {
                    const cpuPct = Math.round((chip.cpu.totalCores / maxCpuCores) * 100);
                    const gpuCores = chip.gpu.maxCores ?? chip.gpu.cores;
                    const gpuPct = Math.round((gpuCores / maxGpuCores) * 100);
                    const bench = chip.benchmarks.geekbench6MultiCore ?? chip.benchmarks.antutu;
                    const benchMax = chip.benchmarks.geekbench6MultiCore ? maxGB6Multi : maxAnTuTu;
                    const benchPct = bench ? Math.round((bench / benchMax) * 100) : null;
                    const benchLabel = chip.benchmarks.geekbench6MultiCore ? 'GB6' : 'AnTuTu';
                    return (
                      <div style="display: flex; flex-direction: column; gap: 5px; margin-bottom: 10px;">
                        <div>
                          <div style="display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 2px;">
                            <span style="font-size: 10px; color: var(--color-text-secondary);">CPU {chip.cpu.totalCores}コア</span>
                            <span style={`font-size: 10px; color: ${chip.color};`}>{cpuPct}%</span>
                          </div>
                          <div style="height: 3px; background: rgba(255,255,255,0.08); border-radius: 2px; overflow: hidden;">
                            <div style={`width: ${cpuPct}%; height: 100%; background: ${chip.color}; border-radius: 2px;`}></div>
                          </div>
                        </div>
                        <div>
                          <div style="display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 2px;">
                            <span style="font-size: 10px; color: var(--color-text-secondary);">GPU {gpuCores}コア</span>
                            <span style={`font-size: 10px; color: ${chip.color};`}>{gpuPct}%</span>
                          </div>
                          <div style="height: 3px; background: rgba(255,255,255,0.08); border-radius: 2px; overflow: hidden;">
                            <div style={`width: ${gpuPct}%; height: 100%; background: linear-gradient(90deg, ${chip.color}80, ${chip.color}); border-radius: 2px;`}></div>
                          </div>
                        </div>
                        {benchPct && (
                          <div>
                            <div style="display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 2px;">
                              <span style="font-size: 10px; color: var(--color-text-secondary);">{benchLabel}</span>
                              <span style={`font-size: 10px; color: ${chip.color};`}>{benchPct}%</span>
                            </div>
                            <div style="height: 3px; background: rgba(255,255,255,0.08); border-radius: 2px; overflow: hidden;">
                              <div style={`width: ${benchPct}%; height: 100%; background: linear-gradient(90deg, ${chip.color}60, ${chip.color}); border-radius: 2px;`}></div>
                            </div>
                          </div>
                        )}
                      </div>
                    );
                  })()}
                  <div style="display: flex; flex-wrap: wrap; gap: 6px;">
                    {chip.highlights.slice(0, 2).map(h => (
                      <span style={`
                        font-size: 11px;
                        padding: 3px 8px;
                        border-radius: 4px;
                        background: ${chip.color}15;
                        color: ${chip.color};
                      `}>{h.slice(0, 20)}</span>
                    ))}
                  </div>
                </a>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .timeline-card:hover {
    border-color: var(--color-accent) !important;
    transform: translateX(4px);
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  function initReveal() {
    ScrollTrigger.getAll().forEach(t => t.kill());
    gsap.utils.toArray<HTMLElement>('.reveal').forEach((el) => {
      gsap.fromTo(el, { x: -30, opacity: 0 }, {
        x: 0, opacity: 1, duration: 0.8, ease: 'power3.out',
        scrollTrigger: { trigger: el, start: 'top 88%', once: true },
      });
    });
    ScrollTrigger.refresh();
  }

  document.addEventListener('astro:page-load', initReveal);
</script>
